uhi:hasRiskFactor a owl:ObjectProperty ;
    rdfs:label "has heat risk factor" ;
    rdfs:domain bot:Building ;
    rdfs:range uhi:HeatRiskFactor .

alkis:UnbekannteFunktion a uhi:BuildingFunction ;
    rdfs:label "Unbekannte Funktion"@de,
        "Unknown function"@en .

uhi:HighAbsorptionRoof a owl:Class ;
    rdfs:label "High solar absorption roof" ;
    rdfs:comment "Flat roof — maximum solar gain, minimal self-shading, poor nighttime radiation." ;
    rdfs:subClassOf uhi:HeatRiskFactor .

uhi:LargeFootprint a owl:Class ;
    rdfs:label "Large sealed footprint" ;
    rdfs:comment "Footprint > 500 m² — contributes disproportionately to surface sealing and heat retention." ;
    rdfs:subClassOf uhi:HeatRiskFactor .

uhi:TallBuilding a owl:Class ;
    rdfs:label "Tall building" ;
    rdfs:comment "Height > 20 m — contributes to urban canyon geometry, trapping longwave radiation at street level." ;
    rdfs:subClassOf uhi:HeatRiskFactor .

uhi:BuildingFunction a owl:Class ;
    rdfs:label "Building function" .

alkis:Zeltdach a uhi:RoofType ;
    rdfs:label "Zeltdach"@de,
        "Pyramid/tent roof"@en ;
    uhi:alkisCode "4000" .

uhi:CityDistrict a owl:Class ;
    rdfs:label "City district" ;
    rdfs:comment "A named administrative sub-district of Stuttgart (Stadtbezirk)." ;
    rdfs:subClassOf sosa:FeatureOfInterest,
        bot:Zone .

uhi:HeatRiskFactor a owl:Class ;
    rdfs:label "Heat risk factor" ;
    rdfs:comment "A property of a building that contributes to urban heat island risk." .

uhi:RoofType a owl:Class ;
    rdfs:label "Roof type" .

alkis:Mansarddach a uhi:RoofType ;
    rdfs:label "Mansarddach"@de,
        "Mansard roof"@en ;
    uhi:alkisCode "3500" .

uhi:HeatDayObservation a owl:Class ;
    rdfs:label "Heat day observation" ;
    rdfs:comment "A temperature observation where the result exceeds 30°C (DWD heat day threshold)." ;
    rdfs:subClassOf uhi:TemperatureObservation .

uhi:LargeFootprintInstance a uhi:HeatRiskFactor,
        uhi:LargeFootprint ;
    rdfs:label "Large footprint risk factor" .

alkis:GewerblichesGebaeude a uhi:BuildingFunction ;
    rdfs:label "Gewerbliches Gebäude"@de,
        "Commercial/industrial building"@en ;
    rdfs:comment "ALKIS prefix 51009" .

alkis:Kuppeldach a uhi:RoofType ;
    rdfs:label "Kuppeldach"@de,
        "Dome roof"@en ;
    uhi:alkisCode "3200" .

uhi:VulnerableBuilding a owl:Class ;
    rdfs:label "Vulnerable building" ;
    rdfs:comment "Inferred class: a building with ≥2 heat risk factors. Not asserted directly." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( bot:Building [ a owl:Restriction ;
                        owl:minQualifiedCardinality 2 ;
                        owl:onClass uhi:HeatRiskFactor ;
                        owl:onProperty uhi:hasRiskFactor ] ) ] .

ex:Sensor_Zone_513_5402 a sosa:Sensor ;
    rdfs:label "Open-Meteo virtual sensor for Zone_513_5402" ;
    rdfs:comment "Data source: Open-Meteo Historical Weather API (https://open-meteo.com/en/docs/historical-weather-api). Variable: temperature_2m_max. Timezone: Europe/Berlin." .

ex:Sensor_Zone_513_5403 a sosa:Sensor ;
    rdfs:label "Open-Meteo virtual sensor for Zone_513_5403" ;
    rdfs:comment "Data source: Open-Meteo Historical Weather API (https://open-meteo.com/en/docs/historical-weather-api). Variable: temperature_2m_max. Timezone: Europe/Berlin." .

ex:Sensor_Zone_514_5402 a sosa:Sensor ;
    rdfs:label "Open-Meteo virtual sensor for Zone_514_5402" ;
    rdfs:comment "Data source: Open-Meteo Historical Weather API (https://open-meteo.com/en/docs/historical-weather-api). Variable: temperature_2m_max. Timezone: Europe/Berlin." .

ex:Sensor_Zone_514_5403 a sosa:Sensor ;
    rdfs:label "Open-Meteo virtual sensor for Zone_514_5403" ;
    rdfs:comment "Data source: Open-Meteo Historical Weather API (https://open-meteo.com/en/docs/historical-weather-api). Variable: temperature_2m_max. Timezone: Europe/Berlin." .

alkis:UnbekannterDachtyp a uhi:RoofType ;
    rdfs:label "Unbekannt"@de,
        "Unknown roof type"@en ;
    uhi:alkisCode "9999" .

uhi:TallBuildingInstance a uhi:HeatRiskFactor,
        uhi:TallBuilding ;
    rdfs:label "Tall building risk factor" .

alkis:Tonnendach a uhi:RoofType ;
    rdfs:label "Tonnendach"@de,
        "Barrel vault roof"@en ;
    uhi:alkisCode "3100" .

ex:Zone_513_5403 a uhi:CityDistrict,
        sosa:FeatureOfInterest,
        bot:Zone ;
    rdfs:label "Stuttgart tile 513/5403 (NW)"@en .

alkis:Pultdach a uhi:RoofType ;
    rdfs:label "Pultdach"@de,
        "Monopitch roof"@en ;
    uhi:alkisCode "2100" .

alkis:Flachdach a uhi:RoofType ;
    rdfs:label "Flachdach"@de,
        "Flat roof"@en ;
    uhi:alkisCode "1000" .

uhi:FlatRoofInstance a uhi:HeatRiskFactor,
        uhi:HighAbsorptionRoof ;
    rdfs:label "Flat roof risk factor" .

uhi:DailyMaxTemperature a sosa:ObservableProperty ;
    rdfs:label "Daily maximum air temperature",
        "Daily maximum air temperature (°C)" ;
    rdfs:comment "Unit: degrees Celsius (°C)" .

uhi:TemperatureObservation a owl:Class ;
    rdfs:label "Daily temperature observation" ;
    rdfs:subClassOf sosa:Observation .

ex:Zone_513_5402 a uhi:CityDistrict,
        sosa:FeatureOfInterest,
        bot:Zone ;
    rdfs:label "Stuttgart tile 513/5402 (SW)"@en .

alkis:Mischform a uhi:RoofType ;
    rdfs:label "Mischform"@de,
        "Mixed/complex roof form"@en ;
    uhi:alkisCode "5000" .

ex:Zone_514_5403 a uhi:CityDistrict,
        sosa:FeatureOfInterest,
        bot:Zone ;
    rdfs:label "Stuttgart tile 514/5403 (NE)"@en .

ex:Zone_514_5402 a uhi:CityDistrict,
        sosa:FeatureOfInterest,
        bot:Zone ;
    rdfs:label "Stuttgart tile 514/5402 (SE)"@en .

alkis:Wohngebaeude a uhi:BuildingFunction ;
    rdfs:label "Wohngebäude"@de,
        "Residential building"@en ;
    rdfs:comment "ALKIS prefix 31001" .

bot:Building rdfs:subClassOf geo:Feature .

[] a owl:AllDifferent ;
    owl:distinctMembers ( alkis:Flachdach alkis:Pultdach alkis:Tonnendach alkis:Kuppeldach alkis:Mansarddach alkis:Zeltdach alkis:Mischform alkis:UnbekannterDachtyp ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( uhi:FlatRoofInstance uhi:LargeFootprintInstance uhi:TallBuildingInstance ) .

[] a owl:AllDisjointClasses ;
    owl:members ( uhi:HighAbsorptionRoof uhi:LargeFootprint uhi:TallBuilding ) .

